---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getDateSortKey } from "../../utils/format-date";
import { getBlogPosts } from "../../utils/get-blog-posts";

const posts = (await getBlogPosts()).sort(
  (left, right) =>
    getDateSortKey(right.data.date, right.data.time).localeCompare(
      getDateSortKey(left.data.date, left.data.time),
    ) || right.id.localeCompare(left.id),
);
---

<BaseLayout title="blog">
  <section class="blog-index">
    <h2>blog</h2>
    <p class="intro">little posts and yaps live here whatever whatever</p>

    {
      posts.length > 0 ? (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              <p>{formatDate(post.data.date)}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">no posts yet, but the blog wiring is all set up nyaa~</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .blog-index {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 0 1rem;
  }

  .intro,
  .empty-state {
    font-size: 1.15rem;
  }

  .post-list {
    list-style: none;
    margin: 5rem 0 0;
    padding: 0;
  }

  .post-list li + li {
    margin-top: 2rem;
  }

  .post-list a {
    font-size: 1.4rem;
    text-shadow: none;
  }

  .post-list p {
    margin: 0.35rem 0 0;
    font-size: 0.95rem;
  }
</style>
