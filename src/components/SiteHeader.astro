---
interface Props {
  pathname: string;
}

const { pathname } = Astro.props;

const navLinks = [
  { href: "https://loafymage.bandcamp.com", label: "music" },
  { href: "https://github.com/loafykitten", label: "my software" },
  { href: "/blog", label: "blog" },
  { href: "https://threads.com/@loafykitten", label: "threads" },
];

const isCurrentPath = (href: string) =>
  href.startsWith("/") &&
  (pathname === href || (href !== "/" && pathname.startsWith(`${href}/`)));
---

<header class="site-header">
  <img src="/images/banner.png" class="banner" alt="loafykitten banner" />

  <h1 class="header-title">
    <img src="/images/Pocky Dab.webp" alt="loafy's fursona dabbing" />
    ~ loafy's little homepage ~
    <img src="/images/Pocky Blush.webp" alt="loafy's fursona blushing" />
  </h1>

  <nav class="site-links" aria-label="Primary">
    {
      navLinks.map(({ href, label }) => (
        <a href={href} aria-current={isCurrentPath(href) ? "page" : undefined}>
          [{label}]
        </a>
      ))
    }
  </nav>

  <hr class="divider" />
</header>

<style>
  .site-header {
    text-align: center;
  }

  .banner {
    width: 100%;
    max-width: 800px;
    max-height: 150px;
    object-fit: cover;
    object-position: 0 45%;
  }

  .header-title {
    margin: 1.5rem 0 0;
    font-size: 3rem;
  }

  .header-title img {
    width: 50px;
    height: 50px;
    vertical-align: middle;
  }

  .site-links {
    margin: 1rem 0;
  }

  .site-links a {
    margin: 0 1rem;
    font-size: 1.2rem;
    text-shadow: none;
  }

  .site-links a:hover,
  .site-links a[aria-current="page"] {
    color: #f0f0f0;
  }

  .divider {
    margin-top: 2rem;
  }

  @media (max-width: 700px) {
    .banner {
      max-height: 110px;
    }

    .header-title {
      font-size: 2rem;
      line-height: 1.2;
    }

    .header-title img {
      width: 36px;
      height: 36px;
    }

    .site-links a {
      display: inline-block;
      margin: 0.35rem 0.4rem;
      font-size: 1.2rem;
    }
  }
</style>

