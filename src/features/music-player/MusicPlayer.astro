---
interface Props {
  audioSrc: string;
  track: string;
  artist: string;
  title?: string;
}

const {
  audioSrc,
  track,
  artist,
  title = "lofi_player.exe",
} = Astro.props;
const progressId = `track-progress-${crypto.randomUUID()}`;
---

<section class="music-player-shell" aria-labelledby="music-player-title" data-music-player>
  <div class="music-player-window">
    <div class="music-player-titlebar">
      <div class="music-player-lights" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <p id="music-player-title">{title}</p>
      <button class="music-player-close" type="button" aria-label="Decorative window button">
        x
      </button>
    </div>

    <div class="music-player-body">
      <div class="music-player-copy">
        <p class="music-player-track">{track}</p>
        <p class="music-player-artist">{artist}</p>
      </div>

      <audio preload="metadata" src={audioSrc} data-audio-player></audio>

      <div class="music-player-controls">
        <button class="music-player-control" type="button" data-audio-play aria-label="Play or pause song">
          ▶
        </button>
        <div class="music-player-progress-wrap">
          <label class="sr-only" for={progressId}>Song progress</label>
          <input
            id={progressId}
            class="music-player-progress"
            type="range"
            min="0"
            max="100"
            value="0"
            data-audio-progress
          />
          <div class="music-player-times">
            <span data-current-time>0:00</span>
            <span data-total-time>0:00</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import "./music-player.ts";
</script>

<style>
  .music-player-shell {
    margin: 0.5rem auto 0;
    width: fit-content;
    max-width: 182px;
  }

  .music-player-window {
    --player-border: #493556;
    --player-shadow: #f5a9cf;
    --player-text: #3e2950;
    width: min(100%, 178px);
    min-height: 100px;
    border: 2px solid var(--player-border);
    border-radius: 10px;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.55), transparent 35%),
      linear-gradient(180deg, #f8dff2 0%, #d7cafb 100%);
    box-shadow: 5px 5px 0 var(--player-shadow);
    color: var(--player-text);
    overflow: hidden;
    text-shadow: none;
  }

  .music-player-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    padding: 0.25rem 0.35rem;
    background: linear-gradient(90deg, #eda2d0 0%, #c9a7fb 100%);
    border-bottom: 2px solid var(--player-border);
  }

  .music-player-titlebar p {
    margin: 0;
    font-size: 0.62rem;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    white-space: nowrap;
  }

  .music-player-lights {
    display: flex;
    gap: 0.15rem;
  }

  .music-player-lights span,
  .music-player-close {
    width: 9px;
    height: 9px;
    border: 1px solid var(--player-border);
    background: #ffd8ea;
    box-shadow: 1px 1px 0 rgba(73, 53, 86, 0.2);
  }

  .music-player-lights span:nth-child(1) {
    background: #ffcf72;
  }

  .music-player-lights span:nth-child(2) {
    background: #bff6d0;
  }

  .music-player-lights span:nth-child(3) {
    background: #9fe6ff;
  }

  .music-player-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 2px;
    color: var(--player-text);
    font: inherit;
    padding: 0;
    cursor: default;
  }

  .music-player-body {
    padding: 0.45rem 0.5rem 0.5rem;
  }

  .music-player-copy {
    margin: 0;
    text-align: left;
  }

  .music-player-track {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1;
    color: #3f2e57;
    text-transform: lowercase;
  }

  .music-player-artist {
    margin: 0.1rem 0 0;
    font-size: 0.68rem;
    text-transform: lowercase;
    color: #7e5d90;
  }

  .music-player-controls {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    align-items: end;
    gap: 0.45rem;
    margin-top: 0.45rem;
  }

  .music-player-progress-wrap {
    min-width: 0;
  }

  .music-player-progress {
    width: 100%;
    height: 12px;
    margin: 0;
    accent-color: #7fd9ff;
    cursor: pointer;
  }

  .music-player-times {
    display: flex;
    justify-content: space-between;
    margin-top: 0.16rem;
    font-size: 0.58rem;
    line-height: 1;
  }

  .music-player-control {
    width: 28px;
    height: 28px;
    border: 2px solid var(--player-border);
    border-radius: 7px;
    background: linear-gradient(180deg, #b9f6d4 0%, #83d8ff 100%);
    color: var(--player-text);
    font-size: 0.95rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 2px 2px 0 rgba(73, 53, 86, 0.16);
    padding: 0;
  }

  .music-player-control:hover,
  .music-player-control:focus-visible {
    transform: translateY(-1px);
  }

  @media (max-width: 700px) {
    .music-player-shell {
      margin-top: 0.5rem;
      width: min(100%, 340px);
      max-width: 100%;
    }

    .music-player-window {
      width: 100%;
      min-height: 122px;
    }

    .music-player-titlebar {
      padding: 0.3rem 0.4rem;
    }

    .music-player-titlebar p {
      font-size: 0.72rem;
    }

    .music-player-body {
      padding: 0.6rem;
    }

    .music-player-track {
      font-size: 1.15rem;
    }

    .music-player-artist {
      font-size: 0.78rem;
    }

    .music-player-controls {
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 0.55rem;
      margin-top: 0.55rem;
    }

    .music-player-control {
      width: 34px;
      height: 34px;
      font-size: 1.05rem;
    }

    .music-player-progress {
      height: 14px;
    }

    .music-player-times {
      margin-top: 0.2rem;
      font-size: 0.66rem;
    }
  }
</style>
